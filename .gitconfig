[user]
	name = Sinan Kanidağlı
	email = sinan_kanidagli@hotmail.com
[core]
	editor = nvim
	excludesfile = /Users/knid/.gitignore_global
[init]
	defaultBranch = master
[color]
  status = auto
  diff = auto
  branch = auto
  interactive = auto
  grep = auto
  ui = auto
[alias]
  a = "!git status --short | peco | awk '{print $2}' | xargs git add"
  us = "!git status --short | grep 'A '| peco | awk '{print $2}' | xargs git restore --staged"
  d = "diff"
  s = "status"
  c = "commit"
  ap = "!f() { git add . && echo $1 }; f"
[github]
  user = knid
